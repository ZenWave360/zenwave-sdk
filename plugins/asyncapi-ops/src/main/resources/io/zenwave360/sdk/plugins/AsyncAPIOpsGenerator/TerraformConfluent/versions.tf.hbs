terraform {
  required_providers {
    confluent = {
      source  = "confluentinc/confluent"
      version = "~> 2.0"
    }
  }
}

variable "default_partitions" {
  type        = number
  default     = null
  description = "Default partition count for topics that omit partitions in AsyncAPI. If null, the Confluent provider default applies."
}

variable "default_topic_config" {
  type        = map(string)
  default     = {}
  description = "Default topic configuration applied to topics that omit topicConfiguration in AsyncAPI. AsyncAPI values override individual keys."
}
