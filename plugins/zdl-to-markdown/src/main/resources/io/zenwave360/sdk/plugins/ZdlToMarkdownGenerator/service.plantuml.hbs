```plantuml
@startuml
{{#each service.aggregates as |aggregates|}}
    {{~assign "aggregate" (resolveDiagramAggregate this)}}
    {{~assign "entity" (resolveDiagramEntity this)}}
    {{~#if aggregate}}
    {{service.name}} -up-> {{aggregate.name}}
    {{> (partial 'aggregateClass.plantuml') aggregate=aggregate }}
    {{aggregate.name}} *--down- {{entity.name}}
    {{> (partial 'entityClass.plantuml') entity=entity stereotype='aggregate' }}
    {{~else}}
    {{service.name}} -up-> {{entity.name}}
    {{> (partial 'entityClass.plantuml') entity=entity stereotype='aggregate' }}
    {{~/if}}
    {{~#each (entityAssociations entity) as |association|}}
    {{association.source}} {{association.linkType}}down- {{association.entity.name}}
    {{~/each}}
    {{~#each (associationTargets (entityAssociations entity) entity.name) as |relatedEntity|}}
    {{~#if (eq relatedEntity.type 'enums')}}
    {{> (partial 'enumClass.plantuml') enum=relatedEntity }}
    {{~else}}
    {{> (partial 'entityClass.plantuml') entity=relatedEntity }}
    {{~/if}}
    {{~/each}}
{{/each}}

class {{service.name}}  << service >> {
{{~#each service.methods as |method|}}
{{~#each (methodAnnotations method) as |annotation|}}
    {{{annotation}}}
{{~/each}}
    {{method.name}}({{methodParamsSignature method}}): {{methodReturnType method}}{{#if (methodEvents method)}} withEvents {{methodEvents method}}{{/if}}
{{~/each}}
}

{{assign "inputs" (serviceInputs service)}}
{{#if inputs}}
    {{service.name}} -left-> inputs
    namespace inputs #DDDDDD {
    {{~#each inputs as |entity|}}
        {{> (partial 'entityClass.plantuml') stereotype=entity.type }}
    {{~/each}}
    {{~#each (collectionAssociations inputs) as |association|}}
        {{association.source}} {{association.linkType}}down- {{association.entity.name}}
    {{~/each}}
    {{~#each (associationTargets (collectionAssociations inputs)) as |relatedEntity|}}
        {{~#if (eq relatedEntity.type 'enums')}}
        {{> (partial 'enumClass.plantuml') enum=relatedEntity }}
        {{~else}}
        {{> (partial 'entityClass.plantuml') entity=relatedEntity }}
        {{~/if}}
    {{~/each}}
    }
{{/if}}

{{assign "outputs" (serviceOutputs service)}}
{{#if outputs}}
    {{service.name}} -right-> outputs
    namespace outputs #DDDDDD {
    {{~#each outputs as |entity|}}
        {{> (partial 'entityClass.plantuml') stereotype=entity.type }}
    {{~/each}}
    {{~#each (collectionAssociations outputs) as |association|}}
        {{association.source}} {{association.linkType}}down- {{association.entity.name}}
    {{~/each}}
    {{~#each (associationTargets (collectionAssociations outputs)) as |relatedEntity|}}
        {{~#if (eq relatedEntity.type 'enums')}}
        {{> (partial 'enumClass.plantuml') enum=relatedEntity }}
        {{~else}}
        {{> (partial 'entityClass.plantuml') entity=relatedEntity }}
        {{~/if}}
    {{~/each}}
    }
{{/if}}

{{assign "events" (serviceEvents service)}}
{{#if events}}
    {{service.name}} -down-> events
    namespace events #DDDDDD {
    {{~#each events as |event|}}
        {{> (partial 'entityClass.plantuml') entity=event stereotype=event.type }}
    {{~/each}}
    }
{{/if}}
@enduml

```
