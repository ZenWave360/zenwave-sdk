package {{layout.entitiesPackage}}

{{~assign "_entity" entity}}
object {{entityServiceTransitionsClassName entity}} {

{{#each (entityServiceTransitionMethods entity) as |method|}}
    fun {{transitionMethodName method}}(entity: {{_entity.className}}) {
        require("{{method.name}}", entity, {{entityCommandFromStatesSignature method _entity}})
    }

{{/each}}
    private fun require(command: String, entity: {{entity.className}}, vararg allowed: {{entityLifecycleFieldType entity}}) {
        val current = entity.{{entity.options.lifecycle.field}}
        if (current != null && allowed.any { it == current }) {
            return
        }
        throw InvalidStateTransitionException(
            entityType = entity::class.simpleName ?: "{{entity.className}}",
            entityId = entity.id,
            naturalId = {{{transitionNaturalIdExpression entity}}},
            operation = command,
            currentState = current,
            allowedStates = allowed.toList()
        )
    }

    class InvalidStateTransitionException(
        val entityType: String,
        val entityId: Any?,
        val naturalId: Any?,
        val operation: String,
        val currentState: Any?,
        val allowedStates: List<*>
    ) : IllegalStateException(
        "Invalid state transition for $entityType (${naturalId ?: "id=$entityId"}): " +
                "operation '$operation' not allowed from state $currentState, allowed states: $allowedStates"
    )
}
