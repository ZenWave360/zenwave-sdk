package {{layout.entitiesPackage}}

import java.util.Optional

import {{layout.domainEventsPackage}}.*
import {{layout.inboundDtosPackage}}.*

import org.mapstruct.MappingTarget
import org.mapstruct.factory.Mappers

class {{aggregate.name}} {
    companion object {
        private val mapper = Mappers.getMapper(Mapper::class.java)
    }

    private val rootEntity: {{aggregate.aggregateRoot}}

    constructor() : this({{aggregate.aggregateRoot}}()) {
        {{~#if (hasLifecycle aggregate)}}
        rootEntity.{{aggregate.lifecycle.field}} = {{lifecycleFieldType aggregate}}.{{aggregate.lifecycle.initial}}
        {{~/if}}
    }

    constructor(rootEntity: {{aggregate.aggregateRoot}}) {
        this.rootEntity = rootEntity
    }

    fun getId(): {{idJavaType}}? {
        return rootEntity.id
    }

    fun getRootEntity(): {{aggregate.aggregateRoot}} {
        return rootEntity
    }


{{#each aggregate.commands as |method|}}
    {{~> (partial '../../implementation/partials/serviceMethodJavadoc')}}
    fun {{method.name}}({{#if method.parameter}}input: {{method.parameter}}{{/if}}): {{asJavaTypeName method.name}}Result {
		{{~#if method.transition.from}}
        {{aggregateTransitionsClassName ../aggregate}}.{{transitionMethodName method}}(rootEntity)
        {{~/if}}
        // TODO: implement this command
        {{~#if method.parameter}}
        mapper.update(rootEntity, input)
        {{~/if}}
		{{~#if method.transition.to}}
		rootEntity.{{../aggregate.lifecycle.field}} = {{lifecycleFieldType ../aggregate}}.{{method.transition.to}}
        {{~/if}}

        return {{asJavaTypeName method.name}}Result(
            rootEntity{{~#each (methodEvents method) as |event|}},
            Optional.of(mapper.as{{event.name}}(rootEntity)){{~/each}}
        )
    }
{{/each}}

{{#each aggregate.commands as |method|}}
    data class {{asJavaTypeName method.name}}Result(
        val aggregateRoot: {{aggregate.aggregateRoot}}{{~#each (methodEvents method) as |event|}},
        val {{asInstanceName event.name}}: Optional<{{event.className}}>{{~/each}}
    )

{{/each}}

    @org.mapstruct.Mapper
    interface Mapper {
        {{~#each (findAggregateInputs aggregate) as |input|}}
        {{~#if input}}
        fun update(@MappingTarget entity: {{aggregate.aggregateRoot}}, input: {{input}}): {{aggregate.aggregateRoot}}
        {{~/if}}
        {{~/each}}

        {{~#each (aggregateEvents aggregate) as |event|}}
        fun as{{event.name}}(entity: {{aggregate.aggregateRoot}}): {{event.className}}
        {{~/each}}
    }
}
