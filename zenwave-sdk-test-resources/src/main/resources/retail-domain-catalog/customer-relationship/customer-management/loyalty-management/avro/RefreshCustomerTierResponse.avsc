{
  "type": "record",
  "name": "RefreshCustomerTierResponse",
  "namespace": "com.acme.customerrelationship.customermanagement.loyaltymanagement.responses",
  "doc": "Response for a loyalty tier refresh request.",
  "fields": [
    { "name": "customerId", "type": "string" },
    { "name": "loyaltyMemberId", "type": "string" },
    { "name": "success", "type": "boolean" },
    {
      "name": "tier",
      "type": {
        "type": "enum",
        "name": "LoyaltyTier",
        "symbols": ["BRONZE", "SILVER", "GOLD", "PLATINUM"]
      }
    },
    { "name": "processedAt", "type": { "type": "long", "logicalType": "timestamp-millis" } },
    { "name": "correlationId", "type": ["null", "string"], "default": null }
  ]
}
